{
  "name": "election-companion-ai",
  "version": "1.1.0",
  "description": "AI-powered civic assistant guiding voters through election processes, eligibility, timelines, and registration — powered by Google Gemini and Vertex AI.",
  "main": "server.js",
  "author": "Election Companion AI Team",
  "license": "ISC",
  "keywords": ["election", "ai", "gemini", "vertex-ai", "civic", "voting", "firebase"],
  "scripts": {
    "start":    "node server.js",
    "dev":      "node --watch server.js",
    "test":     "node -e \"console.log('Open index.html in a browser and run tests.js via the console.')\"",
    "lint":     "node --check server.js app.js decision-engine.js firebase-config.js",
    "validate": "node -e \"require('./server.js')\" && echo 'Server module OK'"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "commonjs",
  "dependencies": {
    "@google-cloud/vertexai": "^1.12.0",
    "@google/genai":          "^1.50.1",
    "cors":                   "^2.8.6",
    "dotenv":                 "^17.4.2",
    "express":                "^5.2.1",
    "firebase-admin":         "^13.8.0"
  }
}
